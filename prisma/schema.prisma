generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Exercise {
  id                    String   @id @default(cuid())
  nombre                String
  grupoMuscularPrincipal String
  gruposSecundarios     String[]
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Routine {
  id          String   @id @default(cuid())
  nombre      String
  plan        Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id            String   @id @default(cuid())
  nombre        String
  correo        String   @unique
  password      String
  rol           String   @default("usuario")
  fechaRegistro DateTime @default(now())
  bloqueado     Boolean  @default(false)
  fechaBloqueo  DateTime?
  edad          Int?
  peso          Float?
  altura        Int?
  genero        String?
  objetivo      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  workoutLogs   WorkoutLog[]
  routineProgresses RoutineProgress[]
}

model WorkoutLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String   // "YYYY-MM-DD"
  exercises Json     // Estado de cada ejercicio en ese día
  history   Json?    // Resumen diario (intensidad, tiempo, musculos)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}

model RoutineProgress {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  routineId          String
  // Routine doesn't have User relation yet, so we just use routineId as string, 
  // or relate it to Routine without adding back-relation if possible, but Prisma requires back-relation for Routine.
  // To keep it simple and not modify Routine, we can just use routineId as a regular String without foreign key relation to Routine.
  // But wait, it's better to relate it if Routine exists. I'll just leave it as String since Routines in DB are global for now,
  // or they match frontend UUIDs.
  completedExercises Json?
  dayComments        Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  
  @@unique([userId, routineId])
}
