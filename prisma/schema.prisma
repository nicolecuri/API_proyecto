generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Exercise {
  id                    String   @id @default(cuid())
  nombre                String
  grupoMuscularPrincipal String
  gruposSecundarios     String[]
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Routine {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nombre      String
  plan        Json
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  routineProgresses  RoutineProgress[]
}

model User {
  id            String   @id @default(cuid())
  nombre        String
  correo        String   @unique
  password      String
  rol           String   @default("usuario")
  fechaRegistro DateTime @default(now())
  bloqueado     Boolean  @default(false)
  fechaBloqueo  DateTime?
  edad          Int?
  peso          Float?
  altura        Int?
  genero        String?
  objetivo      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  routines      Routine[]
  workoutLogs   WorkoutLog[]
  routineProgresses RoutineProgress[]
}

model WorkoutLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String   // "YYYY-MM-DD"
  exercises Json     // Estado de cada ejercicio en ese día
  history   Json?    // Resumen diario (intensidad, tiempo, musculos)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}

model RoutineProgress {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  routineId          String
  routine            Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)
  completedExercises Json?
  dayComments        Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  
  @@unique([userId, routineId])
}
